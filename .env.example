# Board Configuration (github | gitlab)
OFLOW_BOARD=github

# GitHub Settings (required when OFLOW_BOARD=github)
OFLOW_GITHUB_TOKEN=ghp_your_token_here
OFLOW_GITHUB_REPO=owner/repo

# GitLab board (required when OFLOW_BOARD=gitlab)
OFLOW_GITLAB_TOKEN=
OFLOW_GITLAB_PROJECT_ID=owner/repo
# OFLOW_GITLAB_URL=https://gitlab.com/api/v4

# Task Labels
OFLOW_TASK_LABEL=oflow-ready
OFLOW_TASK_IN_PROGRESS_LABEL=oflow-in-progress
OFLOW_TASK_DONE_LABEL=oflow-done

# Agent Configuration
OFLOW_AGENT=claude-code
OFLOW_AGENT_MODEL=claude-opus-4-6

# Concurrency (optional, default: 1)
OFLOW_MAX_CONCURRENT_TASKS=1

# Workflow (optional, default: dev-workflow)
OFLOW_DEFAULT_WORKFLOW=dev-workflow

# Polling (optional, default: 60)
OFLOW_POLL_INTERVAL_SECONDS=60
